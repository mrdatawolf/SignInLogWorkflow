<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign-In Log Workflow" Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9">

  <Window.Resources>
    <!-- Sidebar button style -->
    <Style x:Key="NavButton" TargetType="Button">
      <Setter Property="Background"       Value="Transparent"/>
      <Setter Property="Foreground"       Value="#94A3B8"/>
      <Setter Property="BorderThickness"  Value="0"/>
      <Setter Property="Padding"          Value="16,10"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="FontSize"         Value="13"/>
      <Setter Property="Cursor"           Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Margin="8,2">
              <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#334155"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Active nav button -->
    <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Background" Value="#334155"/>
    </Style>

    <!-- Primary action button -->
    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background"      Value="#2563EB"/>
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="16,8"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bd" Property="Background" Value="#93C5FD"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Secondary button -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Background" Value="#64748B"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#475569"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Success button -->
    <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Background" Value="#16A34A"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#15803D"/>
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Background" Value="#86EFAC"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Card style -->
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background"     Value="White"/>
      <Setter Property="CornerRadius"   Value="8"/>
      <Setter Property="Padding"        Value="16"/>
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="#000000"/>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Settings text input -->
    <Style x:Key="TextInput" TargetType="TextBox">
      <Setter Property="BorderBrush"    Value="#CBD5E1"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"        Value="8,6"/>
      <Setter Property="FontSize"       Value="12"/>
      <Setter Property="Background"     Value="White"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="4">
              <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="200"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ═══════════════════════════════════════════ SIDEBAR ══ -->
    <Border Grid.Column="0" Background="#1E293B">
      <DockPanel>
        <!-- Logo -->
        <StackPanel DockPanel.Dock="Top" Margin="16,24,16,32">
          <TextBlock Text="Sign-In Log" Foreground="White"  FontSize="16" FontWeight="Bold"/>
          <TextBlock Text="Workflow"    Foreground="#94A3B8" FontSize="13"/>
        </StackPanel>

        <!-- Nav -->
        <StackPanel DockPanel.Dock="Top">
          <Button Name="btnNavWorkflow" Content="▶  Run Workflow" Style="{StaticResource NavButtonActive}"/>
          <Button Name="btnNavSettings" Content="⚙  Settings"    Style="{StaticResource NavButton}"/>
        </StackPanel>

        <!-- Version at bottom -->
        <TextBlock DockPanel.Dock="Bottom" Text="v1.0" Foreground="#475569"
                   FontSize="11" Margin="16,0,0,16" VerticalAlignment="Bottom"/>
      </DockPanel>
    </Border>

    <!-- ══════════════════════════════════════════ CONTENT ══ -->
    <Grid Grid.Column="1">

      <!-- ── SETUP VIEW ─────────────────────────────────── -->
      <Grid Name="viewSetup" Visibility="Collapsed" Margin="24">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
          <TextBlock Text="System Check" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
          <TextBlock Text="Verifying access to required resources before starting." Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl Name="lstPrechecks">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="24"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Name="icon" Grid.Column="0" Text="●" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                    <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="12" Foreground="{Binding StatusColor}" VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
          <Button Name="btnRetryChecks" Content="Retry Checks" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
          <Button Name="btnProceedToWorkflow" Content="Continue to Workflow →" Style="{StaticResource PrimaryButton}" IsEnabled="False"/>
        </StackPanel>
      </Grid>

      <!-- ── WORKFLOW VIEW ──────────────────────────────── -->
      <Grid Name="viewWorkflow" Visibility="Visible" Margin="24">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Session header -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Name="lblSessionDate" Text="Session: loading…" FontSize="15" FontWeight="SemiBold" Foreground="#0F172A"/>
              <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <ProgressBar Name="sessionProgress" Width="300" Height="8" Minimum="0" Maximum="1" Value="0"
                             Foreground="#2563EB" Background="#E2E8F0"/>
                <TextBlock Name="lblProgress" Text="0 / 0 done" FontSize="12" Foreground="#64748B" Margin="12,0,0,0" VerticalAlignment="Center"/>
              </StackPanel>
            </StackPanel>
            <Button Name="btnLoadClients" Grid.Column="1" Content="Load Clients" Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <!-- Client list + active panel -->
        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- Client list -->
          <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top" Text="Clients" FontSize="14" FontWeight="SemiBold"
                         Foreground="#0F172A" Margin="0,0,0,12"/>
              <DataGrid Name="dgClients"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        HeadersVisibility="Column"
                        GridLinesVisibility="Horizontal"
                        BorderThickness="0"
                        Background="Transparent"
                        RowBackground="Transparent"
                        AlternatingRowBackground="#F8FAFC"
                        HorizontalScrollBarVisibility="Disabled"
                        SelectionMode="Single"
                        FontSize="12">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Abbr"  Binding="{Binding Abbr}"   Width="70"/>
                  <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                </DataGrid.Columns>
              </DataGrid>
            </DockPanel>
          </Border>

          <!-- Active client steps panel -->
          <Border Grid.Column="1" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Name="panelActiveClient">

                <!-- No client loaded state -->
                <StackPanel Name="panelNoClient" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60,0,0">
                  <TextBlock Text="Load clients to begin" FontSize="15" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Active client steps (hidden until a client is active) -->
                <StackPanel Name="panelSteps" Visibility="Collapsed">

                  <!-- Client header -->
                  <StackPanel Margin="0,0,0,20">
                    <TextBlock Name="lblActiveAbbr" Text="" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Name="lblActiveEmail" Text="" FontSize="13" Foreground="#64748B"/>
                  </StackPanel>

                  <!-- Step 1: Open Firefox -->
                  <Border Name="step1Border" CornerRadius="6" Padding="14" Margin="0,0,0,10"
                          Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                    <StackPanel>
                      <TextBlock Text="Step 1 — Open Browser" FontWeight="SemiBold" Foreground="#1E40AF" Margin="0,0,0,8"/>
                      <TextBlock Text="Opens a Firefox private window with the sign-in page."
                                 Foreground="#3B82F6" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                      <Button Name="btnOpenBrowser" Content="Open Firefox Private Window" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                    </StackPanel>
                  </Border>

                  <!-- Step 2: Username -->
                  <Border Name="step2Border" CornerRadius="6" Padding="14" Margin="0,0,0,10"
                          Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                      <TextBlock Text="Step 2 — Enter Username" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                      <TextBlock Text="Username has been copied to clipboard. Paste it (Ctrl+V) in the browser."
                                 Foreground="#64748B" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                      <Button Name="btnUsernameDone" Content="✓ Username entered — copy password" Style="{StaticResource SuccessButton}"
                              HorizontalAlignment="Left" IsEnabled="False"/>
                    </StackPanel>
                  </Border>

                  <!-- Step 3: Password -->
                  <Border Name="step3Border" CornerRadius="6" Padding="14" Margin="0,0,0,10"
                          Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                      <TextBlock Text="Step 3 — Enter Password" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                      <TextBlock Text="Password is now in clipboard. Paste it (Ctrl+V), sign in, then download both Interactive and NonInteractive JSON files."
                                 Foreground="#64748B" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                      <Button Name="btnFilesDone" Content="✓ Files downloaded — move to share" Style="{StaticResource SuccessButton}"
                              HorizontalAlignment="Left" IsEnabled="False"/>
                    </StackPanel>
                  </Border>

                  <!-- Step 4: Move + Import -->
                  <Border Name="step4Border" CornerRadius="6" Padding="14" Margin="0,0,0,10"
                          Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                      <TextBlock Text="Step 4 — Import to Database" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                      <TextBlock Name="lblMoveStatus" Text="Waiting…" Foreground="#64748B" FontSize="12" Margin="0,0,0,8"/>
                      <!-- Import log -->
                      <Border Background="#0F172A" CornerRadius="4" Padding="10" Margin="0,0,0,10"
                              Visibility="Collapsed" Name="importLogBorder">
                        <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto" Name="importLogScroll">
                          <TextBlock Name="lblImportLog" Foreground="#94A3B8" FontFamily="Consolas" FontSize="11"
                                     TextWrapping="Wrap"/>
                        </ScrollViewer>
                      </Border>
                      <TextBlock Name="lblImportResult" Text="" Foreground="#16A34A" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                    </StackPanel>
                  </Border>

                  <!-- Navigation row -->
                  <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Name="btnSkipClient" Content="Skip Client" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Name="btnNextClient" Content="Next Client →" Style="{StaticResource PrimaryButton}" IsEnabled="False"/>
                  </StackPanel>

                </StackPanel>

                <!-- All done state -->
                <StackPanel Name="panelAllDone" Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,60,0,0">
                  <TextBlock Text="✓ All clients complete!" FontSize="18" FontWeight="Bold"
                             Foreground="#16A34A" HorizontalAlignment="Center"/>
                  <TextBlock Name="lblFinalSummary" Text="" FontSize="13" Foreground="#64748B"
                             HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

              </StackPanel>
            </ScrollViewer>
          </Border>

        </Grid>
      </Grid>

      <!-- ── SETTINGS VIEW ──────────────────────────────── -->
      <Grid Name="viewSettings" Visibility="Collapsed" Margin="24">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
          <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
          <TextBlock Text="Paths are loaded from .env — override here if needed." Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
          <StackPanel>

            <TextBlock Text="UNC Base Folder" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
            <TextBox Name="txtBaseFolder" Style="{StaticResource TextInput}" Margin="0,0,0,16"/>

            <TextBlock Text="Admin Emails File" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
            <TextBox Name="txtAdminEmailsFile" Style="{StaticResource TextInput}" Margin="0,0,0,16"/>

            <TextBlock Text="Downloads Folder" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
            <TextBox Name="txtDownloadsFolder" Style="{StaticResource TextInput}" Margin="0,0,0,16"/>

            <Separator Margin="0,8,0,16"/>

            <TextBlock Text="Resolved Paths (read-only)" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
            <TextBlock Name="lblResolvedPaths" Foreground="#64748B" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap"/>

          </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
          <Button Name="btnSaveSettings" Content="Save Settings" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>

      </Grid>

    </Grid>
  </Grid>
</Window>
